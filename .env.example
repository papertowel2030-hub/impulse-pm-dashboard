# Public database URL created by: npx dexie-cloud create
VITE_DEXIE_CLOUD_URL=

# Comma-separated SHA-256 hashes (hex, lowercase) of emails always allowed in,
# independent of workspace sync state. Never put the plaintext email here — this
# value ships in the public JS bundle. Generate with:
#   printf '%s' "you@example.com" | shasum -a 256 | awk '{print $1}'
VITE_OWNER_EMAIL_HASHES=

# Maps each member's hashed email to "Moon" or "Kira" so task/note attribution and the
# top-bar identity come from who is actually logged in, not a self-picked label.
# Format: hash1:Moon,hash2:Kira
VITE_MEMBER_EMAIL_HASHES=
